# Environment Variables for Public Website

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Razorpay — LIVE keys required for real bank/UPI charges (Dashboard → Live Mode)
# Test keys (rzp_test_...) only simulate payments; netbanking will NOT debit your account.
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_live_secret
# Optional fallback (checkout uses keyId from create-order API when available)
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
